# Example environment configuration for the EMS data simulator.
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored — never commit real credentials or tokens.

# ---------------------------------------------------------------------------
# Locust delivery target
# ---------------------------------------------------------------------------
# Base URL of the CCE data ingestion endpoint.
TARGET_HOST="http://localhost:8001"
# Path on TARGET_HOST that reports are POSTed to (employer-provided endpoint).
INGEST_PATH="/"

# ---------------------------------------------------------------------------
# Simulation timeline / volume
# ---------------------------------------------------------------------------
# Reports pre-generated per device (168 = one week at 1h intervals).
NUM_REPORTS="168"
# Simulated start date (ISO 8601).
SIM_START="2024-06-15T00:00:00"
# Max random offset (seconds) applied to each user's start time.
START_JITTER_S="3600"

# ---------------------------------------------------------------------------
# Delivery transport — CCE data delivery spec compliance
# Defaults are spec-compliant; leave AUTH_TOKEN and GZIP unset to disable.
# ---------------------------------------------------------------------------
# Charset declared in the Content-Type header (spec §1.1/§1.2).
# Sent as: Content-Type: application/json; charset=<CHARSET>
CHARSET="utf-8"

# Authentication (spec §1.3). Token is placed in AUTH_HEADER, optionally
# prefixed by AUTH_SCHEME. When AUTH_TOKEN is unset, NO auth header is sent.
#   API-key:  AUTH_HEADER=x-api-key       (no scheme)         -> x-api-key: <token>
#   Bearer:   AUTH_HEADER=Authorization   AUTH_SCHEME=Bearer  -> Authorization: Bearer <token>
#   Basic:    AUTH_HEADER=Authorization   AUTH_SCHEME=Basic   -> Authorization: Basic <token>
AUTH_HEADER="x-api-key"
AUTH_SCHEME=""
#AUTH_TOKEN="your-token-here"

# Gzip the request body as raw binary + set Content-Encoding: gzip (spec §1.6).
# Truthy values: 1 / true / yes / on.  Bodies are capped at 1MB after
# compression (spec §1.4). Leave unset/empty to send uncompressed JSON.
#GZIP="true"

# ---------------------------------------------------------------------------
# Azure SQL export (optional — for the database export path, not Locust)
# ---------------------------------------------------------------------------
AZURE_USER="your-db-user"
AZURE_PASSWORD="your-db-password"
AZURE_DB="your-database"
AZURE_SERVER="your-server.database.windows.net"
AZURE_ODBC_DRIVER="ODBC Driver 18 for SQL Server"
